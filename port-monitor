# ── 轻量 YAML 解析 ───────────────────────────────────────────

def _yaml_parse(text):
    """解析本项目生成的 YAML 子集：key: value、嵌套缩进、列表（含多字段 dict 项）。"""
    root = {}
    stack = [(root, -1)]
    list_key = None
    current_item = None  # 当前正在构建的列表 dict 项
    current_item_indent = -1

    for raw_line in text.splitlines():
        line = raw_line.rstrip()
        if not line or line.lstrip().startswith("#"):
            continue

        indent = len(line) - len(line.lstrip())
        stripped = line.lstrip()

        # 列表项续行：缩进比列表头更深，且当前有一个 dict 项在构建
        if (current_item is not None
                and indent > current_item_indent
                and not stripped.startswith("- ")
                and ":" in stripped):
            k, v = stripped.split(":", 1)
            current_item[k.strip()] = _yaml_value(v.strip())
            continue

        # 新行不是续行，结束当前列表项
        if current_item is not None and (not stripped.startswith("- ") or indent <= current_item_indent):
            current_item = None

        # 回退到正确的缩进层级
        while len(stack) > 1 and indent <= stack[-1][1]:
            stack.pop()

        parent = stack[-1][0]

        if stripped.startswith("- "):
            val = stripped[2:].strip()
            if list_key and list_key in parent:
                target = parent[list_key]
                if isinstance(target, list):
                    # 仅当冒号后跟空格时才视为 dict 项（避免 URL 等含冒号值被误判）
                    colon_pos = val.find(":")
                    if (colon_pos > 0 and colon_pos + 1 < len(val)
                            and val[colon_pos + 1] == " "
                            and not val.startswith('"')):
                        # dict 列表项的第一行
                        item = {}
                        k, v = val.split(":", 1)
                        item[k.strip()] = _yaml_value(v.strip())
                        target.append(item)
                        current_item = item
                        current_item_indent = indent
                    else:
                        target.append(_yaml_value(_handle_strip_comments(val)))
                        current_item = None
            list_key = None
            continue

        if ":" in stripped:
            key, val = stripped.split(":", 1)
            key = key.strip().strip('"')
            val = val.strip()
            current_item = None

            if val == "":
                node = {}
                parent[key] = node
                stack.append((node, indent))
                list_key = None
            elif val == "[]":
                parent[key] = []
                list_key = key
            else:
                parent[key] = _yaml_value(_handle_strip_comments(val))
                list_key = None

    return root


def _yaml_value(s):
    if s.startswith('"') and s.endswith('"'):
        return s[1:-1]
    if s.startswith("'") and s.endswith("'"):
        return s[1:-1]
    low = s.lower()
    if low == "true":
        return True
    if low == "false":
        return False
    if low in ("null", "~"):
        return None
    try:
        return int(s)
    except ValueError:
        pass
    try:
        return float(s)
    except ValueError:
        pass
    return s


def _handle_strip_comments(s):
    """去除 YAML 值中的行尾注释（不在引号内的 # 注释）。"""
    in_quote = None
    for i, ch in enumerate(s):
        if ch in ('"', "'") and in_quote is None:
            in_quote = ch
        elif ch == in_quote:
            in_quote = None
        elif ch == '#' and in_quote is None and i > 0 and s[i - 1] == ' ':
            return s[:i - 1].rstrip()
    return s


def load_config(path):
    with open(path, "r", encoding="utf-8") as f:
        text = f.read()
    return _yaml_parse(text)


def validate_config(config):
    """校验配置合法性，返回 (warnings, errors) 列表。"""
    warnings = []
    errors = []

    # 监控间隔
    interval = config.get("monitor", {}).get("interval", "5s")
    sec = parse_duration(interval)
    if sec < 1:
        errors.append(f"monitor.interval 过小: {interval}")
    elif sec < 3:
        warnings.append(f"monitor.interval 过小 ({interval})，可能影响性能")

    # 检测规则
    rules = config.get("rules", {})
    scan = rules.get("port_scan", {})
    thresholds = scan.get("thresholds", {})
    if thresholds.get("low", 0) >= thresholds.get("medium", 10):
        errors.append("port_scan.thresholds.low 应小于 medium")
    if thresholds.get("medium", 0) >= thresholds.get("high", 50):
        errors.append("port_scan.thresholds.medium 应小于 high")

    # 暴力破解端口
    for p in rules.get("brute_force", {}).get("sensitive_ports", []):
        if isinstance(p, dict):
            port = p.get("port")
            if not port:
                errors.append("brute_force.sensitive_ports 中缺少 port 字段")
            elif not (1 <= int(port) <= 65535):
                errors.append(f"brute_force 端口无效: {port}")

    # 蜜罐端口
    hp = config.get("honeypot", {})
    if hp.get("enabled"):
        hp_ports = hp.get("ports", [])
        if not hp_ports:
            errors.append("honeypot.enabled=true 但未配置端口")
        # 检查蜜罐端口是否与敏感端口冲突
        brute_ports = {int(p.get("port", 0)) for p in
                       rules.get("brute_force", {}).get("sensitive_ports", [])
                       if isinstance(p, dict)}
        for p in hp_ports:
            if int(p) in brute_ports:
                warnings.append(f"蜜罐端口 {p} 与暴力破解敏感端口冲突")

    # 防火墙方法
    method = config.get("ban", {}).get("method", "iptables")
    if method not in ("iptables", "firewalld", "nftables"):
        errors.append(f"未知的 ban.method: {method}")

    # API 配置
    api = config.get("api", {})
    if api.get("enabled"):
        port = int(api.get("port", 0))
        if not (1 <= port <= 65535):
            errors.append(f"api.port 无效: {port}")
        if not api.get("token"):
            warnings.append("api.enabled=true 但未设置 token，存在安全风险")

    # 分布式联动
    fed = config.get("federation", {})
    if fed.get("enabled"):
        peers = fed.get("peers", [])
        if not peers:
            errors.append("federation.enabled=true 但未配置 peers")
        for i, peer in enumerate(peers):
            if isinstance(peer, dict) and not peer.get("url"):
                errors.append(f"federation.peers[{i}] 缺少 url")

    return warnings, errors


# ── 时间解析 ──────────────────────────────────────────────────

def parse_duration(s):
    """将 '30m', '1h', '24h', '7d' 转为秒数。"""
    if isinstance(s, (int, float)):
        return int(s)
    s = str(s).strip()
    try:
        if s.endswith("s"):
            return int(s[:-1])
        if s.endswith("m"):
            return int(s[:-1]) * 60
        if s.endswith("h"):
            return int(s[:-1]) * 3600
        if s.endswith("d"):
            return int(s[:-1]) * 86400
        return int(s)
    except (ValueError, TypeError):
        logger.warning("无效的时间格式: %s, 使用默认值 300s", s)
        return 300


# ── IP 工具 ───────────────────────────────────────────────────

def normalize_ip(ip):
    """规范化 IP 地址：IPv4-mapped IPv6 转为纯 IPv4，IPv6 统一小写压缩。"""
    try:
        addr = ipaddress.ip_address(ip)
        if isinstance(addr, ipaddress.IPv6Address) and addr.ipv4_mapped:
            return str(addr.ipv4_mapped)
        return str(addr)
    except ValueError:
        return ip


def ip_version(ip):
    """返回 IP 版本号（4 或 6），无效地址返回 0。"""
    try:
        return ipaddress.ip_address(ip).version
    except ValueError:
        return 0


def is_ipv6(ip):
    """判断是否为 IPv6 地址（规范化后）。"""
    return ip_version(normalize_ip(ip)) == 6


