class APIServer:
    """轻量 HTTP API 服务器，在后台线程运行。"""

    def __init__(self, host, port, token=""):
        self.host = host
        self.port = port
        self.token = token
        self._server = None
        self._thread = None

    def start(self, engine):
        """启动 API 服务器。"""
        APIHandler.engine = engine
        APIHandler.api_token = self.token
        try:
            self._server = http.server.HTTPServer(
                (self.host, self.port), APIHandler)
            self._thread = threading.Thread(
                target=self._server.serve_forever, daemon=True)
            self._thread.start()
            logger.info("API 服务已启动: http://%s:%d", self.host, self.port)
        except Exception as e:
            logger.error("API 服务启动失败: %s", e)

    def stop(self):
        """停止 API 服务器。"""
        if self._server:
            self._server.shutdown()
            logger.info("API 服务已停止")


