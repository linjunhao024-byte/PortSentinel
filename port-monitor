class EnhancedAdaptive:
    """按时段学习流量基线，动态调整检测阈值，检测异常突增。"""

    def __init__(self, config):
        ea_cfg = config.get("rules", {}).get("adaptive", {})
        self._enabled = ea_cfg.get("enabled", False)
        self._multiplier = float(ea_cfg.get("multiplier", 3.0))
        self._anomaly_factor = float(ea_cfg.get("anomaly_factor", 10.0))
        self._hourly = defaultdict(lambda: {"ips": [], "syns": []})
        self._dow = defaultdict(lambda: {"ips": [], "syns": []})
        self._samples = 0
        self._MIN_SAMPLES = 12

    def update(self, snapshot, now):
        if not self._enabled:
            return
        hour = int(time.strftime("%H", time.localtime(now)))
        dow = int(time.strftime("%w", time.localtime(now)))
        unique_ips = len(snapshot)
        total_syns = sum(len(s["timestamps"]) for s in snapshot.values())
        self._hourly[hour]["ips"].append(unique_ips)
        self._hourly[hour]["syns"].append(total_syns)
        self._dow[dow]["ips"].append(unique_ips)
        self._dow[dow]["syns"].append(total_syns)
        self._samples += 1
        for store in (self._hourly, self._dow):
            for key in store:
                for metric in ("ips", "syns"):
                    lst = store[key][metric]
                    if len(lst) > 168:
                        store[key][metric] = lst[-168:]

    def get_scan_threshold(self, base_threshold, now=None):
        if not self._enabled or self._samples < self._MIN_SAMPLES:
            return base_threshold
        now = now or time.time()
        hour = int(time.strftime("%H", time.localtime(now)))
        baseline = self._hourly.get(hour, {}).get("ips", [])
        if not baseline:
            return base_threshold
        avg = sum(baseline) / len(baseline)
        return max(int(avg * self._multiplier), base_threshold)

    def get_brute_threshold(self, port, base_threshold, now=None):
        if not self._enabled or self._samples < self._MIN_SAMPLES:
            return base_threshold
        now = now or time.time()
        hour = int(time.strftime("%H", time.localtime(now)))
        baseline = self._hourly.get(hour, {}).get("syns", [])
        if not baseline:
            return base_threshold
        avg = sum(baseline) / len(baseline)
        return max(int(avg * self._multiplier / 5), base_threshold)

    def check_anomaly(self, current_ips, current_syns, now=None):
        if not self._enabled or self._samples < self._MIN_SAMPLES:
            return None
        now = now or time.time()
        hour = int(time.strftime("%H", time.localtime(now)))
        baseline_ips = self._hourly.get(hour, {}).get("ips", [])
        baseline_syns = self._hourly.get(hour, {}).get("syns", [])
        if not baseline_ips:
            return None
        avg_ips = sum(baseline_ips) / len(baseline_ips)
        avg_syns = sum(baseline_syns) / len(baseline_syns) if baseline_syns else 0
        if avg_ips > 0 and current_ips > avg_ips * self._anomaly_factor:
            return {"metric": "unique_ips", "current": current_ips,
                    "baseline": round(avg_ips), "ratio": round(current_ips / avg_ips, 1)}
        if avg_syns > 0 and current_syns > avg_syns * self._anomaly_factor:
            return {"metric": "total_syns", "current": current_syns,
                    "baseline": round(avg_syns), "ratio": round(current_syns / avg_syns, 1)}
        return None


# ── 导出与 Prometheus ─────────────────────────────────────────

class ExportManager:
    """攻击数据导出：CSV / JSON / Prometheus metrics。"""

    def __init__(self, db):
        self.db = db

    def export_csv(self, days=30):
        cur = self.db.conn.execute(
            "SELECT timestamp, src_ip, attack_type, dst_port, blocked "
            "FROM attacks WHERE timestamp >= datetime('now', ?) "
            "ORDER BY timestamp DESC LIMIT 50000",
            (f"-{days} days",))
        lines = ["timestamp,src_ip,attack_type,dst_port,blocked"]
        for r in cur.fetchall():
            lines.append(f"{r[0]},{r[1]},{r[2]},{r[3]},{r[4]}")
        return "\n".join(lines)

    def export_json(self, days=30):
        cur = self.db.conn.execute(
            "SELECT timestamp, src_ip, attack_type, dst_port, blocked "
            "FROM attacks WHERE timestamp >= datetime('now', ?) "
            "ORDER BY timestamp DESC LIMIT 50000",
            (f"-{days} days",))
        records = [{"timestamp": r[0], "src_ip": r[1], "attack_type": r[2],
                    "dst_port": r[3], "blocked": bool(r[4])} for r in cur.fetchall()]
        return {"export_time": time.strftime("%Y-%m-%d %H:%M:%S"),
                "period_days": days, "total": len(records), "records": records}

    def prometheus_metrics(self):
        lines = ["# HELP portsentinel_blocked_ips Number of currently blocked IPs",
                 "# TYPE portsentinel_blocked_ips gauge"]
        try:
            blocked = self.db.conn.execute("SELECT COUNT(*) FROM blocked_ips").fetchone()[0]
        except Exception:
            blocked = 0
        lines.append(f"portsentinel_blocked_ips {blocked}")
        lines.append("# HELP portsentinel_attacks_total Total attacks by type")
        lines.append("# TYPE portsentinel_attacks_total counter")
        try:
            for r in self.db.conn.execute(
                    "SELECT attack_type, COUNT(*) FROM attacks GROUP BY attack_type").fetchall():
                lines.append(f'portsentinel_attacks_total{{type="{r[0]}"}} {r[1]}')
        except Exception:
            pass
        return "\n".join(lines) + "\n"


# ── 分布式集群管理 ────────────────────────────────────────────

class FederationManager:
    """集群节点管理：双向封禁同步 + 配置下发 + 状态监控。"""

    def __init__(self, config, db, firewall):
        self._cfg = config.get("federation", {})
        self._enabled = self._cfg.get("enabled", False)
        self._sync_interval = parse_duration(self._cfg.get("sync_interval", "60s"))
        self._secret = self._cfg.get("cluster_secret", "")
        self._node_id = self._cfg.get("node_id", socket.gethostname())
        self._peers = []
        for p in self._cfg.get("peers", []):
            if isinstance(p, dict) and p.get("url"):
                self._peers.append({"url": p["url"].rstrip("/"), "token": p.get("token", "")})
        self._db = db
        self._firewall = firewall
        self._stats = {"peers_ok": 0, "peers_fail": 0, "bans_synced": 0, "bans_pushed": 0}
        self._last_sync = 0

    def maybe_sync(self):
        if not self._enabled or not self._peers:
            return
        now = time.time()
        if now - self._last_sync < self._sync_interval:
            return
        self._last_sync = now
        ok = fail = synced = pushed = 0
        for peer in self._peers:
            try:
                bans = self._pull_bans(peer)
                if bans is None:
                    fail += 1
                    continue
                ok += 1
                for ban in bans:
                    ip = normalize_ip(ban.get("ip", ""))
                    if not ip or self._db.is_blocked(ip) or self._firewall.is_whitelisted(ip):
                        continue
                    perm = ban.get("permanent", False)
                    dur = PERMANENT_BAN_SECONDS if perm else self._calc_remaining(ban)
                    if self._firewall.ban(ip):
                        self._db.block_ip(ip, f"peer:{ban.get('attack_type', 'unknown')}", dur, permanent=perm)
                        synced += 1
                pushed += self._push_bans(peer)
            except Exception:
                fail += 1
        self._stats = {"peers_ok": ok, "peers_fail": fail,
                       "bans_synced": synced, "bans_pushed": pushed}

    def _pull_bans(self, peer):
        url = f"{peer['url']}/api/bans"
        headers = {}
        if peer.get("token"):
            headers["Authorization"] = f"Bearer {peer['token']}"
        try:
            req = urllib.request.Request(url, headers=headers, method="GET")
            with urllib.request.urlopen(req, timeout=15) as resp:
                return json.loads(resp.read()).get("bans", [])
        except Exception:
            return None

    def _push_bans(self, peer):
        url = f"{peer['url']}/api/sync"
        cur = self._db.conn.execute(
            "SELECT ip, attack_type, unblock_at, permanent FROM blocked_ips")
        bans = [{"ip": r[0], "attack_type": r[1], "unblock_at": r[2], "permanent": bool(r[3])}
                for r in cur.fetchall()]
        body = json.dumps({"node_id": self._node_id, "bans": bans}).encode()
        headers = {"Content-Type": "application/json"}
        if peer.get("token"):
            headers["Authorization"] = f"Bearer {peer['token']}"
        try:
            req = urllib.request.Request(url, data=body, headers=headers, method="POST")
            with urllib.request.urlopen(req, timeout=15) as resp:
                return json.loads(resp.read()).get("synced", 0)
        except Exception:
            return 0

    @staticmethod
    def _calc_remaining(ban):
        try:
            unblock_ts = time.mktime(time.strptime(ban.get("unblock_at", ""), "%Y-%m-%d %H:%M:%S"))
            return max(int(unblock_ts - time.time()), 60)
        except (ValueError, TypeError):
            return 86400

    @property
    def stats(self):
        return self._stats

    @property
    def cluster_info(self):
        return {"node_id": self._node_id, "peers": len(self._peers),
                "enabled": self._enabled, "stats": self._stats}


# ── HTTP API 服务 ─────────────────────────────────────────────

class APIHandler(http.server.BaseHTTPRequestHandler):
    """轻量 HTTP API 请求处理器。"""

    engine = None  # 由 PortSentinel 启动时注入
    api_token = ""

    def log_message(self, format, *args):
        """重定向到 logger。"""
        logger.debug("API: %s", format % args)

    def _check_auth(self):
        """Token 认证检查（常量时间比较防时序攻击）。"""
        if not self.api_token:
            return True
        token = None
        auth = self.headers.get("Authorization", "")
        if auth.startswith("Bearer "):
            token = auth[7:]
        elif "?" in self.path:
            qs = parse_qs(urlparse(self.path).query)
            if "token" in qs:
                token = qs["token"][0]
        if token is None:
            return False
        return hmac.compare_digest(token, self.api_token)

    def _respond(self, code, data):
        """发送 JSON 响应。"""
        body = json.dumps(data, ensure_ascii=False).encode("utf-8")
        self.send_response(code)
        self.send_header("Content-Type", "application/json; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def do_GET(self):
        if not self._check_auth():
            self._respond(401, {"error": "未授权"})
            return

        path = urlparse(self.path).path

        if path == "/api/status":
            self._handle_status()
        elif path == "/api/bans":
            self._handle_bans()
        elif path == "/api/stats":
            self._handle_stats()
        elif path == "/api/health":
            self._handle_health()
        elif path == "/api/timeseries":
            self._handle_timeseries()
        elif path == "/api/history":
            self._handle_history()
        elif path == "/api/threat-intel":
            self._handle_threat_intel()
        elif path == "/api/threat-intel/stats":
            self._handle_threat_intel_stats()
        elif path == "/api/export/csv":
            self._handle_export_csv()
        elif path == "/api/export/json":
            self._handle_export_json()
        elif path == "/api/metrics":
            self._handle_prometheus()
        elif path == "/api/correlation":
            self._handle_correlation()
        elif path == "/api/cluster":
            self._handle_cluster()
        elif path in ("/", "/dashboard", "/index.html"):
            self._serve_dashboard()
        else:
            self._respond(404, {"error": "未知端点",
                                "endpoints": ["/api/status", "/api/bans",
                                              "/api/stats", "/api/health",
                                              "/api/timeseries", "/api/history",
                                              "/api/export/csv", "/api/export/json",
                                              "/api/metrics", "/api/threat-intel",
                                              "/api/correlation", "/api/cluster",
                                              "/dashboard"]})

    def do_POST(self):
        if not self._check_auth():
            self._respond(401, {"error": "未授权"})
            return

        path = urlparse(self.path).path

        try:
            content_length = int(self.headers.get("Content-Length", 0))
        except ValueError:
            content_length = 0
        if content_length > 1048576:  # 限制 1MB 防 OOM
            self._respond(413, {"error": "请求体过大"})
            return
        body = self.rfile.read(content_length) if content_length > 0 else b""

        try:
            data = json.loads(body) if body else {}
        except json.JSONDecodeError:
            self._respond(400, {"error": "无效的 JSON"})
            return

        if path == "/api/ban":
            self._handle_ban(data)
        elif path == "/api/unban":
            self._handle_unban(data)
        else:
            self._respond(404, {"error": "未知端点"})

    def _handle_status(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        uptime = int(time.time() - engine.start_time)
        resp = {
            "version": VERSION,
            "uptime_seconds": uptime,
            "packets": engine.pkt_count,
            "ban_hits": engine.ban_hit_count,
            "firewall": engine.firewall.method,
            "ban_mode": engine.firewall.ban_mode,
            "check_interval": engine.check_interval,
            "adaptive": engine.adaptive_enabled,
            "honeypot": engine.honeypot_enabled,
        }
        if engine.fed_enabled:
            resp["federation"] = {
                "peers": len(engine.fed_peers),
                "stats": engine._fed_stats,
            }
        self._respond(200, resp)

    def _handle_bans(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        try:
            cur = engine.db.conn.execute(
                "SELECT ip, attack_type, blocked_at, unblock_at, permanent "
                "FROM blocked_ips ORDER BY blocked_at DESC")
            bans = []
            for row in cur.fetchall():
                bans.append({
                    "ip": row[0], "attack_type": row[1],
                    "blocked_at": row[2], "unblock_at": row[3],
                    "permanent": bool(row[4])
                })
            self._respond(200, {"count": len(bans), "bans": bans})
        except Exception as e:
            logger.debug("API error: %s", e); self._respond(500, {"error": "内部错误"})

    def _handle_stats(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        try:
            db = engine.db.conn
            total = db.execute(
                "SELECT COUNT(*) FROM attacks").fetchone()[0]
            blocked = db.execute(
                "SELECT COUNT(*) FROM attacks WHERE blocked=1").fetchone()[0]
            unique_ips = db.execute(
                "SELECT COUNT(DISTINCT src_ip) FROM attacks").fetchone()[0]
            by_type = {}
            for row in db.execute(
                    "SELECT attack_type, COUNT(*) FROM attacks "
                    "GROUP BY attack_type").fetchall():
                by_type[row[0]] = row[1]
            recent = []
            for row in db.execute(
                    "SELECT datetime(timestamp,'localtime'), src_ip, "
                    "attack_type, dst_port, blocked "
                    "FROM attacks ORDER BY timestamp DESC LIMIT 20").fetchall():
                recent.append({
                    "time": row[0], "src_ip": row[1],
                    "attack_type": row[2], "dst_port": row[3],
                    "blocked": bool(row[4])
                })
            self._respond(200, {
                "total_attacks": total,
                "blocked": blocked,
                "unique_ips": unique_ips,
                "by_type": by_type,
                "recent": recent,
            })
        except Exception as e:
            logger.debug("API error: %s", e); self._respond(500, {"error": "内部错误"})

    def _handle_health(self):
        engine = self.engine
        checks = {"engine": engine is not None}
        if engine:
            checks["database"] = True
            try:
                engine.db.conn.execute("SELECT 1")
            except Exception:
                checks["database"] = False
            checks["firewall"] = True
        ok = all(checks.values())
        self._respond(200 if ok else 503, {"healthy": ok, "checks": checks})

    def _handle_ban(self, data):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        ip = data.get("ip", "").strip()
        if not ip:
            self._respond(400, {"error": "缺少 ip 参数"})
            return
        ip = normalize_ip(ip)
        if engine.firewall.is_whitelisted(ip):
            self._respond(400, {"error": f"{ip} 在白名单中"})
            return
        if engine.db.is_blocked(ip):
            self._respond(409, {"error": f"{ip} 已被封禁"})
            return
        duration = parse_duration(data.get("duration", "24h"))
        permanent = data.get("permanent", False)
        if engine.firewall.ban(ip):
            engine.db.block_ip(ip, "manual_api", duration, permanent=permanent)
            engine.db.record_attack(ip, "manual_api", 0, blocked=True)
            engine.db.flush()
            self._respond(200, {"ok": True, "ip": ip, "duration": duration})
        else:
            self._respond(500, {"error": "封禁失败"})

    def _handle_unban(self, data):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        ip = data.get("ip", "").strip()
        if not ip:
            self._respond(400, {"error": "缺少 ip 参数"})
            return
        ip = normalize_ip(ip)
        if not engine.db.is_blocked(ip):
            self._respond(404, {"error": f"{ip} 不在封禁列表中"})
            return
        engine.firewall.unban(ip)
        engine.db.unblock_ip(ip)
        self._respond(200, {"ok": True, "ip": ip})

    def _handle_timeseries(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        try:
            cur = engine.db.conn.execute(
                "SELECT strftime('%Y-%m-%d %H:00:00', timestamp) as hour, "
                "attack_type, COUNT(*) as cnt FROM attacks "
                "WHERE timestamp >= datetime('now', '-7 days') "
                "GROUP BY hour, attack_type ORDER BY hour")
            data = {}
            for r in cur.fetchall():
                hour, atype, cnt = r
                if hour not in data:
                    data[hour] = {}
                data[hour][atype] = cnt
            series = [{"hour": h, **counts} for h, counts in sorted(data.items())]
            self._respond(200, {"series": series})
        except Exception:
            self._respond(500, {"error": "查询失败"})

    def _handle_history(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        try:
            qs = parse_qs(urlparse(self.path).query)
            page = max(int(qs.get("page", ["1"])[0]), 1)
            limit = min(int(qs.get("limit", ["50"])[0]), 200)
            offset = (page - 1) * limit
            total = engine.db.conn.execute("SELECT COUNT(*) FROM attacks").fetchone()[0]
            cur = engine.db.conn.execute(
                "SELECT datetime(timestamp,'localtime'), src_ip, attack_type, "
                "dst_port, blocked FROM attacks ORDER BY timestamp DESC LIMIT ? OFFSET ?",
                (limit, offset))
            records = [{"time": r[0], "src_ip": r[1], "attack_type": r[2],
                        "dst_port": r[3], "blocked": bool(r[4])} for r in cur.fetchall()]
            self._respond(200, {"total": total, "page": page, "limit": limit,
                                "pages": (total + limit - 1) // limit, "records": records})
        except Exception:
            self._respond(500, {"error": "查询失败"})

    def _handle_threat_intel(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        qs = parse_qs(urlparse(self.path).query)
        ip = qs.get("ip", [""])[0]
        if not ip:
            self._respond(400, {"error": "缺少 ip 参数"})
            return
        result = engine.threat_intel.check(normalize_ip(ip))
        self._respond(200, {"ip": ip, "intel": result, "cache_size": engine.threat_intel.cache_size})

    def _handle_threat_intel_stats(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        self._respond(200, {"cache_size": engine.threat_intel.cache_size,
                            "enabled": engine.threat_intel._enabled})

    def _handle_export_csv(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        qs = parse_qs(urlparse(self.path).query)
        days = int(qs.get("days", ["30"])[0])
        csv_data = engine.export_manager.export_csv(days)
        body = csv_data.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/csv; charset=utf-8")
        self.send_header("Content-Disposition", "attachment; filename=attacks.csv")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _handle_export_json(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        qs = parse_qs(urlparse(self.path).query)
        days = int(qs.get("days", ["30"])[0])
        data = engine.export_manager.export_json(days)
        self._respond(200, data)

    def _handle_prometheus(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        metrics = engine.export_manager.prometheus_metrics()
        uptime = int(time.time() - engine.start_time)
        metrics += f"portsentinel_uptime_seconds {uptime}\n"
        metrics += f"portsentinel_packets_total {engine.pkt_count}\n"
        metrics += f"portsentinel_ban_hits_total {engine.ban_hit_count}\n"
        metrics += f"portsentinel_running 1\n"
        body = metrics.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/plain; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)

    def _handle_correlation(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        events = engine.attack_correlator.get_active_events()
        self._respond(200, {"active_ips": len(events), "events": events})

    def _handle_cluster(self):
        engine = self.engine
        if not engine:
            self._respond(503, {"error": "引擎未就绪"})
            return
        self._respond(200, engine.federation_manager.cluster_info)

    def _serve_dashboard(self):
        engine = self.engine
        try:
            dashboard_path = os.path.join(os.path.dirname(engine.config_path) if engine else "/etc/port-monitor", "dashboard.html")
            if not os.path.exists(dashboard_path):
                dashboard_path = os.path.join(os.path.dirname(__file__) if "__file__" in dir() else "/usr/local/bin", "dashboard.html")
            if os.path.exists(dashboard_path):
                with open(dashboard_path, "r", encoding="utf-8") as f:
                    body = f.read().encode("utf-8")
            else:
                body = DASHBOARD_HTML.encode("utf-8")
        except Exception:
            body = DASHBOARD_HTML.encode("utf-8")
        self.send_response(200)
        self.send_header("Content-Type", "text/html; charset=utf-8")
        self.send_header("Content-Length", str(len(body)))
        self.end_headers()
        self.wfile.write(body)


