# 常见端口默认服务名（无进程信息时的回退）
WELL_KNOWN_PORTS = {
    20: "FTP-Data", 21: "FTP", 22: "SSH", 23: "Telnet",
    25: "SMTP", 53: "DNS", 80: "HTTP", 110: "POP3",
    143: "IMAP", 443: "HTTPS", 445: "SMB", 465: "SMTPS",
    587: "SMTP-Sub", 993: "IMAPS", 995: "POP3S",
    1433: "MSSQL", 1521: "Oracle", 3306: "MySQL",
    3389: "RDP", 5432: "PostgreSQL", 5900: "VNC",
    6379: "Redis", 6443: "K8s-API", 8080: "HTTP-Alt",
    8443: "HTTPS-Alt", 8888: "HTTP-Alt2", 9090: "Prometheus",
    9200: "Elasticsearch", 11211: "Memcached", 27017: "MongoDB",
}


class PortMapper:
    """端口到进程/服务名的映射，定期刷新。"""

    def __init__(self, refresh_interval=60):
        self._port_map = {}  # port -> service name
        self._refresh_interval = refresh_interval
        self._last_refresh = 0
        self._lock = threading.Lock()

    def get_service(self, port):
        """获取端口对应的服务名。"""
        now = time.time()
        if now - self._last_refresh >= self._refresh_interval:
            self._refresh()
        with self._lock:
            return self._port_map.get(port, WELL_KNOWN_PORTS.get(port, ""))

    def _refresh(self):
        """从 /proc/net/tcp 和 ss 刷新端口映射。"""
        new_map = {}

        # 方法 1: 解析 /proc/net/tcp (IPv4) 和 /proc/net/tcp6 (IPv6)
        for proc_file in ("/proc/net/tcp", "/proc/net/tcp6"):
            try:
                self._parse_proc_net(proc_file, new_map)
            except (OSError, IOError):
                pass

        # 方法 2: 使用 ss 命令补充（更准确的进程信息）
        try:
            self._parse_ss(new_map)
        except (OSError, IOError):
            pass

        with self._lock:
            self._port_map = new_map
            self._last_refresh = time.time()

    def _parse_proc_net(self, filepath, port_map):
        """解析 /proc/net/tcp 获取端口 → inode 映射。"""
        inode_to_port = {}
        try:
            with open(filepath, "r") as f:
                for line in f:
                    parts = line.strip().split()
                    if len(parts) < 10 or parts[0] == "sl":
                        continue
                    local = parts[1]
                    inode = parts[9]
                    port_hex = local.split(":")[1]
                    port = int(port_hex, 16)
                    if port > 0:
                        inode_to_port[inode] = port
        except (OSError, IOError):
            return

        # 通过 /proc/*/fd 链接找到 inode → pid → cmdline
        try:
            for pid_dir in os.listdir("/proc"):
                if not pid_dir.isdigit():
                    continue
                fd_dir = f"/proc/{pid_dir}/fd"
                try:
                    for fd in os.listdir(fd_dir):
                        link = os.readlink(f"{fd_dir}/{fd}")
                        if link.startswith("socket:["):
                            inode = link[8:-1]
                            if inode in inode_to_port:
                                port = inode_to_port[inode]
                                if port not in port_map:
                                    cmdline = self._get_cmdline(pid_dir)
                                    if cmdline:
                                        port_map[port] = cmdline
                except (OSError, IOError):
                    continue
        except (OSError, IOError):
            pass

    def _parse_ss(self, port_map):
        """使用 ss 命令获取端口 → 进程映射。"""
        try:
            result = subprocess.run(
                ["ss", "-tlnp"],
                capture_output=True, text=True, timeout=5)
            if result.returncode != 0:
                return
            for line in result.stdout.splitlines()[1:]:  # 跳过表头
                parts = line.split()
                if len(parts) < 6:
                    continue
                # 解析 local_address 中的端口
                local = parts[3] if len(parts) > 3 else ""
                port_str = local.rsplit(":", 1)[-1] if ":" in local else ""
                try:
                    port = int(port_str)
                except ValueError:
                    continue
                if port in port_map:
                    continue
                # 解析 users:(("name",pid=N,fd=M))
                users_part = line.split("users:(")[-1] if "users:(" in line else ""
                if users_part:
                    proc_name = users_part.split('"')[1] if '"' in users_part else ""
                    if proc_name:
                        port_map[port] = proc_name
        except (OSError, IOError):
            pass

    def _get_cmdline(self, pid):
        """获取进程的命令名。"""
        try:
            with open(f"/proc/{pid}/comm", "r") as f:
                return f.read().strip()
        except (OSError, IOError):
            pass
        try:
            with open(f"/proc/{pid}/cmdline", "r") as f:
                cmdline = f.read().replace("\x00", " ").strip()
                return os.path.basename(cmdline.split()[0]) if cmdline else ""
        except (OSError, IOError):
            return ""


# ── IP 信誉库 + 威胁情报 ─────────────────────────────────────

class ThreatIntel:
    """IP 信誉查询 + 公开威胁情报源同步。"""

    _FEEDS = [
        ("https://iplists.firehol.org/files/firehol_level1.netset", "FireHol_L1"),
        ("https://iplists.firehol.org/files/firehol_level2.netset", "FireHol_L2"),
    ]

    def __init__(self, config):
        self._cfg = config.get("threat_intel", {})
        self._enabled = self._cfg.get("enabled", False)
        self._cache = {}
        self._abuseipdb_key = self._cfg.get("abuseipdb_key", "")
        self._abuseipdb_cache = {}
        self._abuseipdb_cache_ttl = 3600
        self._last_sync = 0
        self._sync_interval = parse_duration(self._cfg.get("sync_interval", "6h"))

    def check(self, ip):
        if not self._enabled:
            return {"risk": "unknown", "source": "disabled"}
        ip_net = ipaddress.ip_network(ip + "/32" if ":" not in ip else ip + "/128", strict=False)
        for cached_net, info in self._cache.items():
            if ip_net.subnet_of(cached_net):
                return info
        if self._abuseipdb_key:
            return self._check_abuseipdb(ip)
        return {"risk": "unknown", "source": "clean"}

    def _check_abuseipdb(self, ip):
        now = time.time()
        if ip in self._abuseipdb_cache:
            ts, result = self._abuseipdb_cache[ip]
            if now - ts < self._abuseipdb_cache_ttl:
                return result
        try:
            url = f"https://api.abuseipdb.com/api/v2/check?ipAddress={ip}&maxAgeInDays=90"
            req = urllib.request.Request(url, method="GET")
            req.add_header("Key", self._abuseipdb_key)
            req.add_header("Accept", "application/json")
            with urllib.request.urlopen(req, timeout=10) as resp:
                data = json.loads(resp.read()).get("data", {})
                score = data.get("abuseConfidenceScore", 0)
                risk = "high" if score > 75 else "medium" if score > 25 else "low"
                result = {"risk": risk, "source": "AbuseIPDB", "score": score,
                          "reports": data.get("totalReports", 0),
                          "country": data.get("countryCode", "")}
                self._abuseipdb_cache[ip] = (now, result)
                return result
        except Exception:
            return {"risk": "unknown", "source": "AbuseIPDB_error"}

    def maybe_sync(self):
        if not self._enabled:
            return
        now = time.time()
        if now - self._last_sync < self._sync_interval:
            return
        self._last_sync = now
        self._sync_feeds()

    def _sync_feeds(self):
        for url, name in self._FEEDS:
            try:
                req = urllib.request.Request(url, method="GET")
                with urllib.request.urlopen(req, timeout=30) as resp:
                    text = resp.read().decode("utf-8", errors="replace")
                    count = 0
                    for line in text.splitlines():
                        line = line.strip()
                        if not line or line.startswith("#"):
                            continue
                        try:
                            net = ipaddress.ip_network(line, strict=False)
                            self._cache[net] = {"risk": "high", "source": name}
                            count += 1
                        except ValueError:
                            pass
                    logger.info("威胁情报同步 %s: %d 条", name, count)
            except Exception as e:
                logger.debug("威胁情报同步失败 %s: %s", name, e)

    @property
    def cache_size(self):
        return len(self._cache) + len(self._abuseipdb_cache)


# ── 攻击行为关联分析 ──────────────────────────────────────────

class AttackCorrelator:
    """追踪 per-IP 的多阶段攻击行为，自动聚合告警。"""

    def __init__(self, config):
        corr_cfg = config.get("correlation", {})
        self._enabled = corr_cfg.get("enabled", False)
        self._window = parse_duration(corr_cfg.get("window", "10m"))
        self._ip_events = defaultdict(list)
        self._lock = threading.Lock()
        self._last_cleanup = time.time()
        self._CLEANUP_INTERVAL = 120

    def record(self, src_ip, attack_type, dst_port, blocked):
        if not self._enabled:
            return None
        now = time.time()
        with self._lock:
            self._ip_events[src_ip].append({
                "time": now, "type": attack_type,
                "port": dst_port, "blocked": blocked})
            self._maybe_cleanup(now)
            return self._analyze_ip(src_ip, now)

    def _analyze_ip(self, src_ip, now):
        events = self._ip_events.get(src_ip, [])
        recent = [e for e in events if now - e["time"] <= self._window]
        if not recent:
            return None
        self._ip_events[src_ip] = recent
        types_seen = set(e["type"] for e in recent)
        if len(types_seen) >= 2:
            type_str = "+".join(sorted(types_seen))
            return {"level": "critical", "summary": f"多阶段攻击: {type_str}",
                    "event_count": len(recent), "types": list(types_seen)}
        if len(recent) >= 10:
            return {"level": "high", "summary": f"持续攻击: {len(recent)} 次",
                    "event_count": len(recent), "types": list(types_seen)}
        return None

    def get_active_events(self):
        """线程安全地获取活跃关联事件（供 API 调用）。"""
        with self._lock:
            result = {}
            now = time.time()
            for ip, evts in self._ip_events.items():
                recent = [e for e in evts if now - e["time"] <= 3600]
                if recent:
                    types = list(set(e["type"] for e in recent))
                    result[ip] = {"count": len(recent), "types": types,
                                  "last": time.strftime('%Y-%m-%d %H:%M:%S',
                                                        time.localtime(recent[-1]["time"]))}
            return result

    def _maybe_cleanup(self, now):
        if now - self._last_cleanup < self._CLEANUP_INTERVAL:
            return
        self._last_cleanup = now
        cutoff = now - self._window * 2
        expired = [ip for ip, events in self._ip_events.items()
                   if not events or events[-1]["time"] < cutoff]
        for ip in expired:
            del self._ip_events[ip]


# ── 自定义响应动作 ────────────────────────────────────────────

class ResponseManager:
    """检测到攻击时执行自定义 Webhook / 脚本。"""

    def __init__(self, config):
        resp_cfg = config.get("response", {})
        self._enabled = resp_cfg.get("enabled", False)
        self._actions = resp_cfg.get("actions", [])
        self._queue = queue.Queue(maxsize=5000)
        self._stopping = threading.Event()
        if self._enabled and self._actions:
            threading.Thread(target=self._run, daemon=True).start()
            logger.info("响应动作: %d 个动作已注册", len(self._actions))

    def trigger(self, context):
        if not self._enabled or not self._actions:
            return
        try:
            self._queue.put_nowait(context)
        except queue.Full:
            pass

    def stop(self):
        self._stopping.set()

    def _run(self):
        while not self._stopping.is_set():
            try:
                ctx = self._queue.get(timeout=5)
            except queue.Empty:
                continue
            for action in self._actions:
                self._execute(action, ctx)

    def _execute(self, action, ctx):
        atype = action.get("type", "")
        tpl = action.get("body", "")
        try:
            if atype == "webhook":
                url = self._render(action.get("url", ""), ctx)
                body = self._render(tpl, ctx) if tpl else json.dumps(ctx)
                method = action.get("method", "POST").upper()
                req = urllib.request.Request(url, data=body.encode(), method=method)
                req.add_header("Content-Type", "application/json")
                with urllib.request.urlopen(req, timeout=10):
                    pass
            elif atype == "script":
                cmd = self._render(action.get("path", ""), ctx)
                args = [self._render(a, ctx) for a in action.get("args", [])]
                subprocess.run([cmd] + args, timeout=30, capture_output=True)
        except Exception as e:
            logger.debug("响应动作失败 [%s]: %s", atype, e)

    @staticmethod
    def _render(template, ctx):
        result = template
        for k, v in ctx.items():
            result = result.replace("{{" + str(k) + "}}", str(v))
        return result


