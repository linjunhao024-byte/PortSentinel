    version INTEGER PRIMARY KEY
);
"""

# 数据库迁移列表：每个迁移是一个 (版本号, SQL语句列表)
DB_MIGRATIONS = [
    # v2: 添加 service_name 列到 attacks 表
    (2, [
        "ALTER TABLE attacks ADD COLUMN service_name TEXT DEFAULT '';",
    ]),
]


class Database:
    def __init__(self, db_path):
        os.makedirs(os.path.dirname(db_path), exist_ok=True)
        self.path = db_path
        self.conn = sqlite3.connect(db_path, check_same_thread=False)
        self.conn.execute("PRAGMA journal_mode=WAL")
        self.conn.execute("PRAGMA synchronous=NORMAL")
        self.conn.executescript(DB_SCHEMA)
        self.conn.commit()
        self._lock = threading.Lock()
        self._blocked_cache = set()
        self._pending_writes = []
        self._load_blocked_cache()
        self._migrate()

    def _migrate(self):
        """执行数据库迁移。"""
        try:
            cur = self.conn.execute(
                "SELECT MAX(version) FROM schema_version")
            current_ver = cur.fetchone()[0] or 0
        except sqlite3.OperationalError:
            current_ver = 0

        for ver, stmts in DB_MIGRATIONS:
            if ver > current_ver:
                try:
                    for stmt in stmts:
                        self.conn.execute(stmt)
                    self.conn.execute(
                        "INSERT OR REPLACE INTO schema_version (version) VALUES (?)",
                        (ver,))
                    self.conn.commit()
                    logger.info("数据库迁移到 v%d 完成", ver)
                except sqlite3.OperationalError as e:
                    logger.debug("迁移 v%d 跳过: %s", ver, e)

    def _load_blocked_cache(self):
        with self._lock:
            cur = self.conn.execute("SELECT ip FROM blocked_ips")
            self._blocked_cache = {row[0] for row in cur.fetchall()}

    def record_attack(self, src_ip, attack_type, dst_port, blocked=False):
        with self._lock:
            if len(self._pending_writes) < 50000:
                self._pending_writes.append(
                    (src_ip, attack_type, dst_port, int(blocked)))

    def flush(self):
        """批量提交所有待写入记录（每检测周期调用一次）。"""
        with self._lock:
            rows = self._pending_writes[:]
            self._pending_writes.clear()
            if rows:
                self.conn.executemany(
                    "INSERT INTO attacks (src_ip, attack_type, dst_port, blocked) "
                    "VALUES (?,?,?,?)", rows)
                self.conn.commit()

    def block_ip(self, ip, attack_type, duration_sec, permanent=False):
        now = time.strftime("%Y-%m-%d %H:%M:%S")
        if permanent:
            unblock_at = "2099-01-01 00:00:00"
            perm = 1
        else:
            unblock_at = time.strftime(
                "%Y-%m-%d %H:%M:%S",
                time.localtime(time.time() + duration_sec))
            perm = 0
        with self._lock:
            self.conn.execute(
                "INSERT OR REPLACE INTO blocked_ips "
                "(ip,attack_type,blocked_at,unblock_at,permanent) VALUES (?,?,?,?,?)",
                (ip, attack_type, now, unblock_at, perm))
            self.conn.commit()
            self._blocked_cache.add(ip)

    def unblock_ip(self, ip):
        with self._lock:
            self.conn.execute("DELETE FROM blocked_ips WHERE ip=?", (ip,))
            self.conn.commit()
            self._blocked_cache.discard(ip)

    def is_blocked(self, ip):
        with self._lock:
            return ip in self._blocked_cache

    def get_expired_bans(self):
        now = time.strftime("%Y-%m-%d %H:%M:%S")
        with self._lock:
            cur = self.conn.execute(
                "SELECT ip FROM blocked_ips WHERE permanent=0 AND unblock_at<=?", (now,))
            return [row[0] for row in cur.fetchall()]

    def close(self):
        self.flush()
        self.conn.close()


# ── 防火墙执行 ────────────────────────────────────────────────

class Firewall:
    def __init__(self, method, whitelist=None, ban_mode="drop"):
        self.method = method
        self.ban_mode = ban_mode  # "drop" | "reject" | "rate_limit"
        self.whitelist = set(whitelist or [])
        self.whitelist.add("127.0.0.1")
        self.whitelist.add("::1")

    def is_whitelisted(self, ip):
        ip = normalize_ip(ip)
        if ip in self.whitelist:
            return True
        try:
            addr = ipaddress.ip_address(ip)
            for entry in self.whitelist:
                if "/" in entry:
                    try:
                        if addr in ipaddress.ip_network(entry, strict=False):
                            return True
                    except ValueError:
                        pass
        except ValueError:
            pass
        return False

    def ban(self, ip):
        if self.is_whitelisted(ip):
            logger.warning("跳过白名单 IP: %s", ip)
            return False
        try:
            v6 = is_ipv6(ip)
            # 确定 iptables/nftables 目标动作
            target = "DROP"
            if self.ban_mode == "reject":
                target = "REJECT"
            elif self.ban_mode == "rate_limit":
                target = "DROP"  # 限速模式仍用 DROP，但先添加 hashlimit ACCEPT 规则

            if self.method == "iptables":
                cmd = "ip6tables" if v6 else "iptables"
                check = subprocess.run(
                    [cmd, "-C", "INPUT", "-s", ip, "-j", target],
                    capture_output=True, timeout=10)
                if check.returncode == 0:
                    logger.info("规则已存在，跳过重复添加: %s", ip)
                    return True
                # 限速模式：先添加 hashlimit ACCEPT 规则
                if self.ban_mode == "rate_limit":
                    safe_name = ip.replace(".", "_").replace(":", "_")[:16]
                    subprocess.run(
                        [cmd, "-I", "INPUT", "-s", ip,
                         "-m", "hashlimit",
                         "--hashlimit", "2/sec",
                         "--hashlimit-burst", "5",
                         "--hashlimit-name", f"ps_{safe_name}",
                         "--hashlimit-mode", "srcip",
                         "-j", "ACCEPT"],
                        capture_output=True, timeout=10)
                result = subprocess.run(
                    [cmd, "-I", "INPUT", "-s", ip, "-j", target],
                    capture_output=True, timeout=10)
            elif self.method == "firewalld":
                family = "ipv6" if v6 else "ipv4"
                action = "reject" if self.ban_mode == "reject" else "drop"
                result = subprocess.run([
                    "firewall-cmd", "--add-rich-rule",
                    f"rule family='{family}' source address='{ip}' {action}",
                    "--permanent"], capture_output=True, timeout=10)
                subprocess.run(
                    ["firewall-cmd", "--reload"],
                    capture_output=True, timeout=10)
            elif self.method == "nftables":
                addr_type = "ip6" if v6 else "ip"
                result = subprocess.run([
                    "nft", "add", "rule", "inet", "filter", "input",
                    addr_type, "saddr", ip, "drop"], capture_output=True, timeout=10)
            else:
                logger.warning("未知防火墙方法: %s", self.method)
                return False

            if hasattr(result, "returncode") and result.returncode != 0:
                stderr = result.stderr.decode(errors="replace").strip()
                logger.error("封禁命令失败 %s: %s", ip, stderr)
                return False

            logger.info("已封禁: %s (via %s)", ip, self.method)
            return True
        except Exception as e:
            logger.error("封禁失败 %s: %s", ip, e)
            return False

    def unban(self, ip):
        try:
            v6 = is_ipv6(ip)
            target = "REJECT" if self.ban_mode == "reject" else "DROP"

            if self.method == "iptables":
                cmd = "ip6tables" if v6 else "iptables"
                # 限速模式：先移除 hashlimit ACCEPT 规则
                if self.ban_mode == "rate_limit":
                    safe_name = ip.replace(".", "_").replace(":", "_")[:16]
                    subprocess.run(
                        [cmd, "-D", "INPUT", "-s", ip,
                         "-m", "hashlimit",
                         "--hashlimit", "2/sec",
                         "--hashlimit-burst", "5",
                         "--hashlimit-name", f"ps_{safe_name}",
                         "--hashlimit-mode", "srcip",
                         "-j", "ACCEPT"],
                        capture_output=True, timeout=10)
                result = subprocess.run(
                    [cmd, "-D", "INPUT", "-s", ip, "-j", target],
                    capture_output=True, timeout=10)
            elif self.method == "firewalld":
                family = "ipv6" if v6 else "ipv4"
                action = "reject" if self.ban_mode == "reject" else "drop"
                result = subprocess.run([
                    "firewall-cmd", "--remove-rich-rule",
                    f"rule family='{family}' source address='{ip}' {action}",
                    "--permanent"], capture_output=True, timeout=10)
                subprocess.run(
                    ["firewall-cmd", "--reload"],
                    capture_output=True, timeout=10)
            elif self.method == "nftables":
                result = subprocess.run(
                    ["nft", "-a", "list", "chain", "inet", "filter", "input"],
                    capture_output=True, text=True, timeout=10)
                if result.returncode == 0:
                    addr_type = "ip6" if v6 else "ip"
                    pattern = re.compile(
                        rf'{addr_type} saddr {re.escape(ip)}.*drop')
                    for line in result.stdout.splitlines():
                        if pattern.search(line):
                            handle_match = re.search(
                                r'\bhandle\s+(\d+)\b', line)
                            if handle_match:
                                subprocess.run([
                                    "nft", "delete", "rule", "inet", "filter",
                                    "input", "handle", handle_match.group(1)],
                                    capture_output=True, timeout=10)
                            else:
                                logger.warning("nftables 解封: 无法提取 handle: %s", line.strip())
                            break
            else:
                return False

            if hasattr(result, "returncode") and result.returncode != 0:
                stderr = result.stderr.decode(errors="replace").strip()
                if "No chain" not in stderr and "No such file" not in stderr:
                    logger.warning("解封命令返回非零: %s: %s", ip, stderr)

            logger.info("已解封: %s", ip)
            return True
        except Exception as e:
            logger.error("解封失败 %s: %s", ip, e)
            return False


# ── 告警推送 ──────────────────────────────────────────────────

class Alerter:
    """异步告警推送：enqueue 非阻塞，后台守护线程聚合发送（防抖）。"""

    _BATCH_MAX = 5       # 聚合条数阈值
    _BATCH_WINDOW = 5.0  # 聚合时间窗口（秒）
    _FLUSH_TIMEOUT = 2.0 # 队列 get 超时（用于时间窗口触发）

    def __init__(self, config):
        self.config = config
        self._queue = queue.Queue(maxsize=10000)
        self._stopping = threading.Event()
        self._worker = threading.Thread(target=self._run, daemon=True)
        self._worker.start()

    def enqueue(self, message):
        """非阻塞入队，由后台线程聚合发送。"""
        try:
            self._queue.put_nowait(message)
        except queue.Full:
            pass

    def stop(self):
        """通知后台线程退出，等待残留消息发送完毕。"""
        self._stopping.set()
        self._worker.join(timeout=30)

    def _run(self):
        """后台守护线程：聚合消费，防抖发送。"""
        buffer = []
        last_flush = time.time()

        while not self._stopping.is_set():
            try:
                msg = self._queue.get(timeout=self._FLUSH_TIMEOUT)
                if msg is not None:
                    buffer.append(msg)
            except queue.Empty:
                pass  # 超时，检查是否需要按时间窗口 flush

            now = time.time()
            should_flush = (
                len(buffer) >= self._BATCH_MAX
                or (buffer and now - last_flush >= self._BATCH_WINDOW)
            )

            if should_flush and buffer:
                self._flush(buffer)
                buffer.clear()
                last_flush = now

        # stopping：排空队列中剩余消息
        while True:
            try:
                msg = self._queue.get_nowait()
                if msg is not None:
                    buffer.append(msg)
            except queue.Empty:
                break

        if buffer:
            self._flush(buffer)

    def _flush(self, messages):
        """将多条消息聚合为一条后发送。"""
        if not messages:
            return
        combined = "\n\n━━━━━━━━━━━━━━━━━━\n\n".join(messages)
        try:
            self._send_telegram(combined)
            self._send_dingtalk(combined)
            self._send_email(combined)
            self._send_wechat(combined)
            self._send_feishu(combined)
            self._send_slack(combined)
        except Exception as e:
            logger.error("告警发送异常: %s", e)

    def _send_telegram(self, msg):
        tg = self.config.get("alert", {}).get("telegram", {})
        if not tg.get("enabled"):
            return
        token = tg.get("bot_token", "")
        chat_id = tg.get("chat_id", "")
        if not token or not chat_id:
            return
        try:
            url = f"https://api.telegram.org/bot{token}/sendMessage"
            data = urllib.parse.urlencode({
                "chat_id": chat_id,
                "text": msg,
