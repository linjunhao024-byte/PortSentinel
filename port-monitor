class PortSentinel:
    def __init__(self, config_path):
        self.config_path = config_path
        self.config = load_config(config_path)
        warns, errs = validate_config(self.config)
        for w in warns:
            logger.warning("配置警告: %s", w)
        for e in errs:
            logger.error("配置错误: %s", e)
        if errs:
            logger.error("配置存在 %d 个错误，部分功能可能异常", len(errs))
        self.running = False

        storage = self.config.get("storage", {})
        self.db_path = storage.get("sqlite", {}).get(
            "path", "/var/lib/port-monitor/monitor.db")
        self.db = Database(self.db_path)

        log_cfg = self.config.get("alert", {}).get("log", {})
        log_path = log_cfg.get(
            "path", "/var/log/port-monitor/port-monitor.log")
        setup_logging(log_path if log_cfg.get("enabled", True) else None)

        ban_cfg = self.config.get("ban", {})
        self.firewall = Firewall(
            ban_cfg.get("method", "iptables"),
            ban_cfg.get("whitelist", []),
            ban_cfg.get("mode", "drop"))

        self.alerter = Alerter(self.config)
        self.port_mapper = PortMapper()

        # 检测参数
        rules = self.config.get("rules", {})
        scan = rules.get("port_scan", {})
        brute = rules.get("brute_force", {})
        ddos = rules.get("ddos", {})

        self.scan_thresholds = scan.get("thresholds", {
            "low": 5, "medium": 10, "high": 50, "critical": 500})
        self.scan_auto_ban = scan.get("auto_ban", True)
        self.scan_ban_duration = parse_duration(
            scan.get("ban_duration", "1h"))
        self.scan_window = parse_duration(scan.get("window", "10s"))

        self.brute_ports = {}
        for p in brute.get("sensitive_ports", []):
            if isinstance(p, dict):
                try:
                    port_num = int(p["port"])
                    threshold_val = int(p.get("threshold", 5))
                except (ValueError, TypeError, KeyError):
                    continue
                self.brute_ports[port_num] = {
                    "name": p.get("name", str(port_num)),
                    "threshold": threshold_val}
        self.brute_auto_ban = brute.get("auto_ban", True)
        self.brute_ban_duration = parse_duration(
            brute.get("ban_duration", "24h"))
        self.brute_permanent = brute.get("permanent", False)
        self.brute_window = parse_duration(brute.get("window", "60s"))

        # 蜜罐端口配置
        honeypot_cfg = self.config.get("honeypot", {})
        self.honeypot_enabled = honeypot_cfg.get("enabled", False)
        self.honeypot_ports = set()
        for p in honeypot_cfg.get("ports", []):
            try:
                self.honeypot_ports.add(int(p))
            except (ValueError, TypeError):
                pass
        self.honeypot_ban_duration = parse_duration(
            honeypot_cfg.get("ban_duration", "7d"))
        self.honeypot_permanent = honeypot_cfg.get("permanent", False)

        try:
            self.ddos_threshold = int(ddos.get("threshold", 1000))
        except (ValueError, TypeError):
            self.ddos_threshold = 1000
        self.ddos_auto_ban = ddos.get("auto_ban", True)
        self.ddos_ban_duration = parse_duration(
            ddos.get("ban_duration", "1h"))
        self.ddos_window = parse_duration(ddos.get("window", "5s"))

        # 自适应阈值配置
        adaptive_cfg = rules.get("adaptive", {})
        self.adaptive_enabled = adaptive_cfg.get("enabled", False)
        self.adaptive_learning_sec = parse_duration(
            adaptive_cfg.get("learning_period", "30m"))
        self.adaptive_multiplier = float(
            adaptive_cfg.get("multiplier", 3.0))
        self.adaptive_recalibrate_sec = parse_duration(
            adaptive_cfg.get("recalibrate_interval", "1h"))
        # 学习期流量统计
        self._baseline_samples = []  # [(timestamp, unique_ips, total_syns)]
        self._baseline_start = time.time()
        self._baseline_calibrated = False
        self._adaptive_scan_threshold = self.scan_thresholds.get("medium", 10)
        self._adaptive_brute_threshold = {}  # port -> threshold
        self._last_calibrate = 0

        self.check_interval = parse_duration(
            self.config.get("monitor", {}).get("interval", "5s"))

        # per-IP 追踪
        self.syn_data = defaultdict(lambda: {
            "ports": deque(maxlen=300),
            "timestamps": deque(maxlen=5000),
            "port_counts": defaultdict(lambda: deque(maxlen=500)),
        })
        self._data_lock = threading.Lock()

        # 告警冷却 + 聚合统计
        self.alert_cooldown = {}  # key -> (timestamp, suppressed_count)
        self.ALERT_COOLDOWN_SEC = 300

        # 告警模板
        self._default_templates = {
            "ban": (
                "🚨 PortSentinel 自动封禁\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━\n"
                "来源: {{src_ip}}\n"
                "类型: {{attack_type}}\n"
                "端口: :{{dst_port}}\n"
                "时长: {{duration}}\n"
                "时间: {{time}}"
            ),
            "port_scan": (
                "🚨 端口扫描 [{{level}}]\n"
                "来源: {{src_ip}}\n"
                "扫描端口: {{count}} 个/{{window}}秒\n"
                "级别: {{level}}"
            ),
            "port_scan_low": (
                "⚠️ 端口扫描 [LOW]\n"
                "来源: {{src_ip}}\n"
                "扫描端口: {{count}} 个/{{window}}秒"
            ),
            "brute_force": (
                "🚨 {{service_name}} 暴力破解\n"
                "来源: {{src_ip}}\n"
                "端口: :{{dst_port}} ({{service}})\n"
                "尝试: {{count}} 次/{{window}}秒"
            ),
            "ddos": (
                "🚨 DDoS 攻击\n"
                "来源: {{src_ip}}\n"
                "SYN 包: {{count}} 个/{{window}}秒"
            ),
            "honeypot": (
                "🍯 蜜罐触发 - 零容忍封禁\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━\n"
                "来源: {{src_ip}}\n"
                "触碰端口: :{{dst_port}}\n"
                "封禁时长: {{duration}}\n"
                "时间: {{time}}\n"
                "主机: {{hostname}}"
            ),
            "alert_summary": (
                "📊 攻击聚合摘要\n"
                "━━━━━━━━━━━━━━━━━━━━━━━━\n"
                "来源: {{src_ip}}\n"
                "类型: {{attack_type}}\n"
                "端口: :{{dst_port}}\n"
                "{{window}}秒内累计 {{count}} 次攻击"
            ),
        }
        self._templates = dict(self._default_templates)
        # 从配置加载自定义模板
        alert_cfg = self.config.get("alert", {})
        for name, tpl in alert_cfg.get("templates", {}).items():
            if isinstance(tpl, str) and tpl.strip():
                self._templates[name] = tpl

        self._sockets = []
        self.pkt_count = 0
        self.ban_hit_count = 0  # 被封禁 IP 的重复攻击尝试次数
        self.start_time = 0

        # API 服务配置
        api_cfg = self.config.get("api", {})
        self.api_enabled = api_cfg.get("enabled", False)
        self.api_host = api_cfg.get("host", "127.0.0.1")
        self.api_port = int(api_cfg.get("port", 8900))
        self.api_token = api_cfg.get("token", "")
        self.api_server = None

        # 分布式联动配置
        fed_cfg = self.config.get("federation", {})
        self.fed_enabled = fed_cfg.get("enabled", False)
        self.fed_sync_interval = parse_duration(
            fed_cfg.get("sync_interval", "60s"))
        self.fed_peers = []
        for peer in fed_cfg.get("peers", []):
            if isinstance(peer, dict):
                url = peer.get("url", "").rstrip("/")
                token = peer.get("token", "")
                if url:
                    self.fed_peers.append({"url": url, "token": token})
        self._fed_last_sync = 0
        self._fed_stats = {"peers_ok": 0, "peers_fail": 0, "bans_synced": 0}

        # 统计：用于定期清理
        self._last_cleanup = 0
        self._CLEANUP_INTERVAL = 300  # 5 分钟清理一次

        # ── 新增功能模块 ──
        self.threat_intel = ThreatIntel(self.config)
        self.attack_correlator = AttackCorrelator(self.config)
        self.response_manager = ResponseManager(self.config)
        self.enhanced_adaptive = EnhancedAdaptive(self.config)
        self.export_manager = ExportManager(self.db)
        self.federation_manager = FederationManager(self.config, self.db, self.firewall)
        self.honeypot_service = HoneypotService(
            self.config, alert_callback=self._honeypot_alert_cb)
        self._capture_stats = {"unique_ips": 0, "total_syns": 0}

    def start(self):
        logger.info("=" * 60)
        logger.info("PortSentinel v%s 启动", VERSION)
        logger.info("配置: %s", self.config_path)
        logger.info("数据库: %s", self.db_path)
        logger.info("防火墙: %s", self.firewall.method)
        logger.info("检测间隔: %ds", self.check_interval)
        if self.brute_ports:
            ports_str = ", ".join(
                f":{p}({c['name']})" for p, c in self.brute_ports.items())
            logger.info("敏感端口: %s", ports_str)
        if self.honeypot_enabled and self.honeypot_ports:
            hp_str = ", ".join(f":{p}" for p in sorted(self.honeypot_ports))
            logger.info("蜜罐端口: %s (零容忍)", hp_str)
        if self.adaptive_enabled:
            logger.info("自适应阈值: 学习期%ds, 倍率%.1f",
                        self.adaptive_learning_sec, self.adaptive_multiplier)
        logger.info("=" * 60)

        self.running = True
        self.start_time = time.time()

        self._restore_bans()

        signal.signal(signal.SIGTERM, self._signal_handler)
        signal.signal(signal.SIGINT, self._signal_handler)
        if hasattr(signal, "SIGHUP"):
            signal.signal(signal.SIGHUP, self._reload_handler)

        # 启动 API 服务
        if self.api_enabled:
            self.api_server = APIServer(
                self.api_host, self.api_port, self.api_token)
            self.api_server.start(self)

        # 启动蜜罐服务
        self.honeypot_service.start()

        # 启动威胁情报同步
        self.threat_intel.maybe_sync()

        detect_thread = threading.Thread(
            target=self._detection_loop, daemon=True)
        detect_thread.start()

        expire_thread = threading.Thread(
            target=self._expire_loop, daemon=True)
        expire_thread.start()

        # 启动分布式联动
        if self.fed_enabled and self.fed_peers:
            fed_thread = threading.Thread(
                target=self._federation_loop, daemon=True)
            fed_thread.start()
            logger.info("分布式联动: %d 个节点, 同步间隔%ds",
                        len(self.fed_peers), self.fed_sync_interval)

        try:
            self._capture_loop()
        except KeyboardInterrupt:
            pass
        finally:
            self.stop()

    def stop(self):
        logger.info("正在停止...")
        self.running = False
        for s in (self._sockets or []):
            try:
                s.close()
            except Exception:
                pass
        if self.api_server:
            self.api_server.stop()
        self.honeypot_service.stop()
        self.response_manager.stop()
        self.alerter.stop()
        self.db.close()
        logger.info("已停止 (处理了 %d 个包)", self.pkt_count)

    def _signal_handler(self, signum, frame):
        logger.info("收到信号 %d", signum)
        self.running = False

    def _reload_handler(self, signum, frame):
        """SIGHUP 处理：热加载配置，不中断服务。"""
        try:
            self._reload_config()
        except Exception as e:
            logger.error("配置热加载失败: %s", e)

    def _reload_config(self):
        """重新加载配置文件，更新运行时参数，保留封禁状态和连接。"""
        logger.info("=" * 40)
        logger.info("收到 SIGHUP，正在热加载配置...")

        new_config = load_config(self.config_path)
        warns, errs = validate_config(new_config)
        for w in warns:
            logger.warning("配置警告: %s", w)
        for e in errs:
            logger.error("配置错误: %s", e)

        # 更新防火墙（白名单可能变化）
        ban_cfg = new_config.get("ban", {})
        self.firewall.method = ban_cfg.get("method", self.firewall.method)
        new_wl = set(ban_cfg.get("whitelist", []))
        new_wl.add("127.0.0.1")
        new_wl.add("::1")
        self.firewall.whitelist = new_wl

        # 更新告警配置和模板
        self.alerter.config = new_config
        alert_cfg = new_config.get("alert", {})
        for name, tpl in alert_cfg.get("templates", {}).items():
            if isinstance(tpl, str) and tpl.strip():
                self._templates[name] = tpl

        # 更新检测规则
        rules = new_config.get("rules", {})
        scan = rules.get("port_scan", {})
        brute = rules.get("brute_force", {})
        ddos = rules.get("ddos", {})

        self.scan_thresholds = scan.get("thresholds", self.scan_thresholds)
        self.scan_auto_ban = scan.get("auto_ban", self.scan_auto_ban)
        self.scan_ban_duration = parse_duration(
            scan.get("ban_duration", self.scan_ban_duration))
        self.scan_window = parse_duration(
            scan.get("window", self.scan_window))

        new_brute_ports = {}
        for p in brute.get("sensitive_ports", []):
            if isinstance(p, dict):
                try:
                    port_num = int(p["port"])
                    threshold_val = int(p.get("threshold", 5))
                except (ValueError, TypeError, KeyError):
                    continue
                new_brute_ports[port_num] = {
                    "name": p.get("name", str(port_num)),
                    "threshold": threshold_val}
        if new_brute_ports:
            self.brute_ports = new_brute_ports
        self.brute_auto_ban = brute.get("auto_ban", self.brute_auto_ban)
        self.brute_ban_duration = parse_duration(
            brute.get("ban_duration", self.brute_ban_duration))
        self.brute_permanent = brute.get("permanent", self.brute_permanent)
        self.brute_window = parse_duration(
            brute.get("window", self.brute_window))

        try:
            self.ddos_threshold = int(ddos.get("threshold", self.ddos_threshold))
        except (ValueError, TypeError):
            pass
        self.ddos_auto_ban = ddos.get("auto_ban", self.ddos_auto_ban)
        self.ddos_window = parse_duration(
            ddos.get("window", self.ddos_window))

        # 更新自适应阈值配置
        adaptive_cfg = rules.get("adaptive", {})
        self.adaptive_enabled = adaptive_cfg.get(
            "enabled", self.adaptive_enabled)
        self.adaptive_learning_sec = parse_duration(
            adaptive_cfg.get("learning_period", self.adaptive_learning_sec))
        self.adaptive_multiplier = float(
            adaptive_cfg.get("multiplier", self.adaptive_multiplier))
        self.adaptive_recalibrate_sec = parse_duration(
            adaptive_cfg.get("recalibrate_interval",
                              self.adaptive_recalibrate_sec))

        # 更新蜜罐配置
        honeypot_cfg = new_config.get("honeypot", {})
        self.honeypot_enabled = honeypot_cfg.get("enabled", self.honeypot_enabled)
        new_hp_ports = set()
        for p in honeypot_cfg.get("ports", []):
            try:
                new_hp_ports.add(int(p))
            except (ValueError, TypeError):
                pass
        if new_hp_ports:
            self.honeypot_ports = new_hp_ports
        self.honeypot_ban_duration = parse_duration(
            honeypot_cfg.get("ban_duration", self.honeypot_ban_duration))
        self.honeypot_permanent = honeypot_cfg.get(
            "permanent", self.honeypot_permanent)

        new_interval = parse_duration(
            new_config.get("monitor", {}).get("interval", self.check_interval))
        self.check_interval = new_interval

        self.config = new_config
        logger.info("配置热加载完成")
        logger.info("  防火墙: %s", self.firewall.method)
        logger.info("  检测间隔: %ds", self.check_interval)
        logger.info("  敏感端口: %s", ", ".join(
            f":{p}({c['name']})" for p, c in self.brute_ports.items()))
        if self.honeypot_enabled:
            logger.info("  蜜罐端口: %s", ", ".join(
                f":{p}" for p in sorted(self.honeypot_ports)))
        logger.info("=" * 40)

    def _restore_bans(self):
        cur = self.db.conn.execute("SELECT ip FROM blocked_ips")
        ips = [row[0] for row in cur.fetchall()]
        if ips:
            logger.info("恢复 %d 条封禁规则...", len(ips))
            for ip in ips:
                self.firewall.ban(ip)

    # ── 抓包 ──────────────────────────────────────────────────

    def _create_socket(self):
        try:
            sock = socket.socket(
                socket.AF_PACKET, socket.SOCK_RAW, socket.ntohs(0x0003))
            logger.info("使用 AF_PACKET 抓包 (双栈 v4+v6)")
            return [sock], "af_packet"
        except (PermissionError, OSError):
            pass

        socks = []
        try:
            sock4 = socket.socket(
                socket.AF_INET, socket.SOCK_RAW, socket.IPPROTO_TCP)
            socks.append(sock4)
        except PermissionError:
            pass

        try:
            sock6 = socket.socket(
                socket.AF_INET6, socket.SOCK_RAW, socket.IPPROTO_TCP)
            socks.append(sock6)
        except (PermissionError, OSError):
            pass

        if not socks:
            logger.error("需要 root 权限运行")
            sys.exit(1)

        logger.info("使用 AF_INET 抓包 (%d 个 socket)", len(socks))
        return socks, "af_inet"

    def _capture_loop(self):
        socks, mode = self._create_socket()
        self._sockets = socks
        for s in socks:
            s.settimeout(1.0)

        logger.info("开始抓包监控...")

        while self.running:
            if len(socks) > 1:
                ready, _, _ = select.select(socks, [], [], 1.0)
                if not ready:
                    continue
                readable = ready
            else:
                readable = socks

            for sock in readable:
                try:
                    data, addr = sock.recvfrom(65535)
                except socket.timeout:
                    continue
                except OSError:
                    if not self.running:
                        return
                    continue

                self.pkt_count += 1

                if mode == "af_packet":
                    src_ip, dst_port = self._parse_af_packet(data)
                else:
                    src_ip, dst_port = self._parse_ip_tcp(data)

                if src_ip and dst_port:
                    src_ip = normalize_ip(src_ip)

                    # 统计被封禁 IP 的重复攻击
                    if self.db.is_blocked(src_ip):
                        self.ban_hit_count += 1
                        continue

                    # 蜜罐端口：零容忍，立即封禁
                    if (self.honeypot_enabled
                            and dst_port in self.honeypot_ports
                            and not self.firewall.is_whitelisted(src_ip)
                            and not self.db.is_blocked(src_ip)):
                        self._execute_honeypot_ban(src_ip, dst_port)
                        continue

                    with self._data_lock:
                        d = self.syn_data[src_ip]
                        d["ports"].append(dst_port)
                        d["timestamps"].append(time.time())
                        d["port_counts"][dst_port].append(time.time())

    def _parse_af_packet(self, data):
        if len(data) < 34:
            return None, None
        eth_proto = struct.unpack("!H", data[12:14])[0]
        if eth_proto == 0x8100:  # VLAN-tagged frame
            if len(data) < 38:
                return None, None
            eth_proto = struct.unpack("!H", data[16:18])[0]
            offset = 18
        elif eth_proto in (0x0800, 0x86DD):  # IPv4 / IPv6
            offset = 14
        else:
            return None, None
        if eth_proto not in (0x0800, 0x86DD):
            return None, None
        return self._parse_ip_tcp(data[offset:])

    def _parse_af_inet(self, data):
        return self._parse_ip_tcp(data)

    def _parse_ip_tcp(self, data):
        if len(data) < 20:
            return None, None
        version = (data[0] >> 4) & 0x0F
        if version == 4:
            return self._parse_ipv4_tcp(data)
        elif version == 6:
            return self._parse_ipv6_tcp(data)
        return None, None

    def _parse_ipv4_tcp(self, data):
        """解析 IPv4 + TCP，提取 SYN 包的源 IP 和目标端口。"""
        ip_ihl = (data[0] & 0x0F) * 4
        if ip_ihl < 20 or len(data) < ip_ihl:
            return None, None
        if data[9] != 6:  # TCP only
            return None, None

        # 检测 IP 分片，丢弃分片包防止绕过
        frag_field = struct.unpack("!H", data[6:8])[0]
        if (frag_field & 0x2000) or (frag_field & 0x1FFF):
            return None, None

        src_ip = socket.inet_ntop(socket.AF_INET, data[12:16])

        tcp_start = ip_ihl
        if len(data) < tcp_start + 14:
            return None, None

        dst_port = struct.unpack(
            "!H", data[tcp_start + 2:tcp_start + 4])[0]
        tcp_flags = data[tcp_start + 13]

        is_syn = (tcp_flags & 0x02) != 0
        is_ack = (tcp_flags & 0x10) != 0
        if not is_syn or is_ack:
            return None, None

        return src_ip, dst_port

    def _parse_ipv6_tcp(self, data):
        """解析 IPv6 + TCP，提取 SYN 包的源 IP 和目标端口。"""
        if len(data) < 40:
            return None, None

        next_header = data[6]
        src_ip = socket.inet_ntop(socket.AF_INET6, data[8:24])

        # 遍历扩展头找到 TCP（next_header=6）
        offset = 40
        for _ in range(10):  # 最多跳 10 层扩展头
            if next_header == 6:
                break
            if next_header in (50, 51):
                return None, None  # ESP/AH 无法简单跳过
            if next_header == 44:
                # Fragment Header 固定 8 字节
                if offset + 8 > len(data):
                    return None, None
                next_header = data[offset]
                offset += 8
            elif next_header in (0, 43, 60, 135):
                # Hop-by-Hop / Routing / Destination / Mobility
                if offset + 2 > len(data):
                    return None, None
                ext_len = (data[offset + 1] + 1) * 8
                next_header = data[offset]
                offset += ext_len
            else:
                return None, None

        if next_header != 6:
            return None, None
        if len(data) < offset + 14:
            return None, None

        dst_port = struct.unpack("!H", data[offset + 2:offset + 4])[0]
        tcp_flags = data[offset + 13]

        is_syn = (tcp_flags & 0x02) != 0
        is_ack = (tcp_flags & 0x10) != 0
        if not is_syn or is_ack:
            return None, None

        return normalize_ip(src_ip), dst_port

    # ── 检测循环 ──────────────────────────────────────────────

    def _detection_loop(self):
        while self.running:
            time.sleep(self.check_interval)
            if not self.running:
                break
            try:
                self._analyze()
                self.db.flush()
                # alerter.flush() 已由后台守护线程自动消费，不再同步阻塞
                self._maybe_cleanup()
            except Exception as e:
                logger.error("检测异常: %s", e)

    def _maybe_cleanup(self):
        """定期清理过期的内存数据，防止泄漏。"""
        now = time.time()
        if now - self._last_cleanup < self._CLEANUP_INTERVAL:
            return
        self._last_cleanup = now

        # 清理告警冷却：移除超过冷却期 2 倍的条目
        cutoff = now - self.ALERT_COOLDOWN_SEC * 2
        expired_keys = [
            k for k, (ts, _) in self.alert_cooldown.items() if ts < cutoff]
        for k in expired_keys:
            del self.alert_cooldown[k]

        # syn_data 的过期清理已在 _analyze 指针交换中自然完成

        if expired_keys:
            logger.debug("清理: %d 条冷却记录", len(expired_keys))

    # ── 自适应阈值 ────────────────────────────────────────────

    def _update_baseline(self, snapshot, now):
        """收集流量基线样本，定期校准自适应阈值。"""
        # 统计本周期的流量特征
        unique_ips = len(snapshot)
        total_syns = sum(
            len(snap["timestamps"]) for snap in snapshot.values())
        self._baseline_samples.append((now, unique_ips, total_syns))

        # 保留最近 1 小时的样本
        cutoff = now - 3600
        self._baseline_samples = [
            (t, ip, syn) for t, ip, syn in self._baseline_samples
            if t >= cutoff
        ]

        # 检查是否需要校准
        elapsed = now - self._baseline_start
        if not self._baseline_calibrated:
            if elapsed >= self.adaptive_learning_sec:
                self._calibrate_thresholds()
                self._baseline_calibrated = True
                logger.info("自适应阈值学习期结束，已校准")
        elif now - self._last_calibrate >= self.adaptive_recalibrate_sec:
            self._calibrate_thresholds()

    def _calibrate_thresholds(self):
        """根据基线样本计算自适应阈值。"""
        if not self._baseline_samples:
            return

        self._last_calibrate = time.time()

        # 计算基线统计
        ip_counts = [s[1] for s in self._baseline_samples]
        syn_counts = [s[2] for s in self._baseline_samples]

        if not ip_counts:
            return

        avg_ips = sum(ip_counts) / len(ip_counts)
        avg_syns = sum(syn_counts) / len(syn_counts) if syn_counts else 0

        # 自适应阈值 = 基线均值 × 倍率，但不低于配置的最小值
        min_scan = self.scan_thresholds.get("medium", 10)
        adaptive_scan = max(
            int(avg_ips * self.adaptive_multiplier), min_scan)
        self._adaptive_scan_threshold = adaptive_scan

        # 暴力破解阈值：基于每个端口的平均连接数
        # 这里用全局平均值作为基准
        for port, cfg in self.brute_ports.items():
            min_thresh = cfg["threshold"]
            adaptive = max(
                int(avg_syns * self.adaptive_multiplier / max(len(self.brute_ports), 1)),
                min_thresh)
            self._adaptive_brute_threshold[port] = adaptive

        logger.info(
            "自适应校准: 基线IP=%.0f SYN=%.0f, 扫描阈值=%d",
            avg_ips, avg_syns, self._adaptive_scan_threshold)

    def _analyze(self):
        """指针交换：O(1) 锁占用，锁外完成全部分析。"""
        # 1. 指针交换：将当前 syn_data 取出，替换为空 defaultdict
        with self._data_lock:
            snapshot = self.syn_data
            self.syn_data = defaultdict(lambda: {
                "ports": deque(maxlen=300),
                "timestamps": deque(maxlen=5000),
                "port_counts": defaultdict(lambda: deque(maxlen=500)),
            })
        # 锁已释放，抓包线程可以继续写入新的 syn_data

        # 2. 锁外分析快照数据
        now = time.time()

        for src_ip, snap in snapshot.items():
            if self.firewall.is_whitelisted(src_ip):
                continue
            if self.db.is_blocked(src_ip):
                continue

            timestamps = list(snap["timestamps"])
            recent_ts = [t for t in timestamps if now - t <= 60]
            if not recent_ts:
                continue

            snap_dict = {
                "ports": list(snap["ports"]),
                "timestamps": timestamps,
                "port_counts": {
                    p: list(ts) for p, ts in snap["port_counts"].items()
                },
            }

            self._detect_port_scan(src_ip, snap_dict, now)
            if self.brute_ports:
                self._detect_brute_force(src_ip, snap_dict, now)
            self._detect_ddos(src_ip, recent_ts, now)

        # 自适应阈值：收集基线样本
        if self.adaptive_enabled:
            self._update_baseline(snapshot, now)

        # 增强自适应：更新时段基线 + 异常检测
        self.enhanced_adaptive.update(snapshot, now)
        snapshot_ips = len(snapshot)
        snapshot_syns = sum(len(s["timestamps"]) for s in snapshot.values())
        anomaly = self.enhanced_adaptive.check_anomaly(snapshot_ips, snapshot_syns, now)
        if anomaly:
            logger.warning("流量异常突增: %s 当前=%d 基线=%d 倍率=%.1f",
                           anomaly["metric"], anomaly["current"],
                           anomaly["baseline"], anomaly["ratio"])

        # 威胁情报：定期同步
        self.threat_intel.maybe_sync()

    def _detect_port_scan(self, src_ip, snap, now):
        window = self.scan_window
        recent_ports = set()
        for port, ts_list in snap["port_counts"].items():
            for t in ts_list:
                if now - t <= window:
                    recent_ports.add(port)
                    break

        count = len(recent_ports)
        if count < 1:
            return

        thresholds = self.scan_thresholds
        level = None
        ban_duration = self.scan_ban_duration

        # 自适应模式：优先使用增强自适应，回退到基础自适应
        adaptive_medium = self.enhanced_adaptive.get_scan_threshold(
            thresholds.get("medium", 10), now)
        if self.adaptive_enabled and self._baseline_calibrated:
            medium = max(self._adaptive_scan_threshold, adaptive_medium)
            low = max(medium // 2, 1)
            high = medium * 5
            critical = medium * 50
        elif adaptive_medium != thresholds.get("medium", 10):
            medium = adaptive_medium
            low = max(medium // 2, 1)
            high = medium * 5
            critical = medium * 50
        else:
            medium = thresholds.get("medium", 10)
            low = thresholds.get("low", 5)
            high = thresholds.get("high", 50)
            critical = thresholds.get("critical", 500)

        if count >= critical:
            level = "critical"
            ban_duration *= 5
        elif count >= high:
            level = "high"
            ban_duration *= 2
        elif count >= medium:
            level = "medium"
        elif count >= low:
            level = "low"

        if level and count >= medium:
            if self.scan_auto_ban and level in ("medium", "high", "critical"):
                # 发送扫描详情告警后再封禁
                self._alert_cooldown(
                    src_ip, "port_scan", 0,
                    self._render_template("port_scan",
                        src_ip=src_ip, level=level.upper(),
                        count=count, window=window))
                self._execute_ban(
                    src_ip, "port_scan", 0, ban_duration)
            else:
                self._alert_cooldown(
                    src_ip, "port_scan", 0,
                    self._render_template("port_scan",
                        src_ip=src_ip, level=level.upper(),
                        count=count, window=window))
        elif level == "low":
            self._alert_cooldown(
                src_ip, "port_scan", 0,
                self._render_template("port_scan_low",
                    src_ip=src_ip, count=count, window=window))

    def _detect_brute_force(self, src_ip, snap, now):
        window = self.brute_window

        for port, port_cfg in self.brute_ports.items():
            # 自适应模式：优先使用增强自适应，回退到基础自适应
            adaptive_thresh = self.enhanced_adaptive.get_brute_threshold(
                port, port_cfg["threshold"], now)
            if (self.adaptive_enabled and self._baseline_calibrated
                    and port in self._adaptive_brute_threshold):
                threshold = max(self._adaptive_brute_threshold[port], adaptive_thresh)
            else:
                threshold = adaptive_thresh
            name = port_cfg["name"]

            ts_list = snap["port_counts"].get(port, [])
            count = sum(1 for t in ts_list if now - t <= window)

            if count >= threshold:
                duration = self.brute_ban_duration
                permanent = self.brute_permanent
                if permanent:
                    duration = PERMANENT_BAN_SECONDS

                if self.brute_auto_ban:
                    self._execute_ban(
                        src_ip, "brute_force", port, duration,
                        permanent=permanent)
                else:
                    svc = self.port_mapper.get_service(port)
                    self._alert_cooldown(
                        src_ip, "brute_force", port,
                        self._render_template("brute_force",
                            src_ip=src_ip, service_name=name,
                            dst_port=port, count=count, window=window,
                            service=svc or name))

    def _detect_ddos(self, src_ip, recent_ts, now):
        window = self.ddos_window
        count = sum(1 for t in recent_ts if now - t <= window)

        if count >= self.ddos_threshold:
            if self.ddos_auto_ban:
                self._execute_ban(
                    src_ip, "ddos", 0, self.ddos_ban_duration)
            else:
                self._alert_cooldown(
                    src_ip, "ddos", 0,
                    self._render_template("ddos",
                        src_ip=src_ip, count=count, window=window))

    # ── 模板渲染 ──────────────────────────────────────────────

    def _render_template(self, template_name, **kwargs):
        """渲染告警模板，支持 {{variable}} 变量替换。"""
        tpl = self._templates.get(template_name, "")
        if not tpl:
            return ""
        result = tpl
        for key, value in kwargs.items():
            result = result.replace("{{" + key + "}}", str(value))
        return result

    # ── 封禁执行 ──────────────────────────────────────────────

    def _execute_ban(self, src_ip, attack_type, dst_port,
                     duration_sec, permanent=False):
        if self.db.is_blocked(src_ip):
            return

        # 威胁情报检查：高风险 IP 延长封禁
        intel = self.threat_intel.check(src_ip)
        if intel.get("risk") == "high" and not permanent:
            duration_sec = max(duration_sec, 86400)
            logger.info("威胁情报命中 %s: %s, 封禁延长至 %s",
                        src_ip, intel.get("source"), self._format_duration(duration_sec))

        success = self.firewall.ban(src_ip)
        if not success:
            return

        self.db.block_ip(
            src_ip, attack_type, duration_sec, permanent=permanent)
        self.db.record_attack(
            src_ip, attack_type, dst_port, blocked=True)

        duration_str = ("永久" if permanent
                        else self._format_duration(duration_sec))
        logger.info(
            "封禁 %s (%s, :%s, %s)",
            src_ip, attack_type, dst_port, duration_str)

        service = self.port_mapper.get_service(dst_port)
        self.alerter.enqueue(self._render_template(
            "ban",
            src_ip=src_ip, attack_type=attack_type,
            dst_port=dst_port, duration=duration_str,
            time=time.strftime('%Y-%m-%d %H:%M:%S'),
            hostname=socket.gethostname(),
            service=service))

        # 攻击关联分析
        correlation = self.attack_correlator.record(src_ip, attack_type, dst_port, True)
        if correlation:
            logger.warning("关联告警 %s: %s (%d 事件)", src_ip, correlation["summary"], correlation["event_count"])
            self.alerter.enqueue(
                f"🔗 关联告警\n来源: {src_ip}\n{correlation['summary']}\n事件数: {correlation['event_count']}")

        # 自定义响应动作
        self.response_manager.trigger({
            "src_ip": src_ip, "attack_type": attack_type,
            "dst_port": dst_port, "duration": duration_str,
            "permanent": permanent, "hostname": socket.gethostname(),
            "time": time.strftime('%Y-%m-%d %H:%M:%S')})

    def _execute_honeypot_ban(self, src_ip, dst_port):
        """蜜罐端口触发：零容忍立即封禁。"""
        if self.db.is_blocked(src_ip):
            return

        permanent = self.honeypot_permanent
        duration = (PERMANENT_BAN_SECONDS if permanent
                    else self.honeypot_ban_duration)

        success = self.firewall.ban(src_ip)
        if not success:
            return

        self.db.block_ip(src_ip, "honeypot", duration, permanent=permanent)
        self.db.record_attack(src_ip, "honeypot", dst_port, blocked=True)

        duration_str = "永久" if permanent else self._format_duration(duration)
        logger.warning(
            "🍯 蜜罐触发封禁 %s (端口 :%s, %s)", src_ip, dst_port, duration_str)

        service = self.port_mapper.get_service(dst_port)
        self.alerter.enqueue(self._render_template(
            "honeypot",
            src_ip=src_ip, dst_port=dst_port,
            duration=duration_str,
            time=time.strftime('%Y-%m-%d %H:%M:%S'),
            hostname=socket.gethostname(),
            service=service))

    def _honeypot_alert_cb(self, src_ip, port, service, data):
        """蜜罐服务捕获攻击者数据的回调。"""
        if self.db.is_blocked(src_ip):
            return
        self._execute_honeypot_ban(src_ip, port)
        safe_data = repr(data[:100]).replace("\n", "\\n")
        self.alerter.enqueue(
            f"🍯 蜜罐数据捕获\n来源: {src_ip}\n端口: :{port} [{service}]\n数据: {safe_data}")

    def _format_duration(self, sec):
        if sec >= PERMANENT_BAN_SECONDS:
            return "永久"
        days = sec // 86400
        hours = (sec % 86400) // 3600
        minutes = (sec % 3600) // 60
        if days > 0:
            return f"{days}天{hours}小时" if hours else f"{days}天"
        if hours > 0:
            return f"{hours}小时{minutes}分钟" if minutes else f"{hours}小时"
        return f"{minutes}分钟"

    # ── 告警冷却 ──────────────────────────────────────────────

    def _alert_cooldown(self, src_ip, attack_type, dst_port, message):
        key = f"{src_ip}|{attack_type}|{dst_port}"
        now = time.time()
        entry = self.alert_cooldown.get(key)

        if entry:
            last_ts, suppressed = entry
            if now - last_ts < self.ALERT_COOLDOWN_SEC:
                # 冷却期内：累计抑制计数，不发送
                self.alert_cooldown[key] = (last_ts, suppressed + 1)
                return
            # 冷却期已过：发送聚合摘要
            if suppressed > 0:
                summary = self._render_template(
                    "alert_summary",
                    src_ip=src_ip, attack_type=attack_type,
                    dst_port=dst_port, count=suppressed,
                    window=self.ALERT_COOLDOWN_SEC,
                    original=message)
                self.db.record_attack(
                    src_ip, attack_type, dst_port, blocked=False)
                self.alerter.enqueue(summary)
                self.alert_cooldown[key] = (now, 0)
                return

        # 首次触发或冷却期后的新攻击
        self.alert_cooldown[key] = (now, 0)
        self.db.record_attack(
            src_ip, attack_type, dst_port, blocked=False)
        self.alerter.enqueue(message)

    # ── 过期解封 ──────────────────────────────────────────────

    def _expire_loop(self):
        while self.running:
            time.sleep(60)
            if not self.running:
                break
            try:
                expired = self.db.get_expired_bans()
                for ip in expired:
                    self.firewall.unban(ip)
                    self.db.unblock_ip(ip)
                    # 清除该 IP 的追踪数据，避免解封后立即重封
                    with self._data_lock:
                        self.syn_data.pop(ip, None)
                    logger.info("自动解封: %s", ip)
            except Exception as e:
                logger.error("过期解封异常: %s", e)

    # ── 分布式联动 ─────────────────────────────────────────────

    def _federation_loop(self):
        """定期从对端节点拉取封禁列表并同步到本地。"""
        while self.running:
            time.sleep(self.fed_sync_interval)
            if not self.running:
                break
            try:
                self._sync_peers()
            except Exception as e:
                logger.error("分布式同步异常: %s", e)

    def _sync_peers(self):
        """从所有对端节点拉取封禁列表并应用。"""
        ok_count = 0
        fail_count = 0
        synced = 0

        for peer in self.fed_peers:
            try:
                bans = self._fetch_peer_bans(peer)
                if bans is None:
                    fail_count += 1
                    continue
                ok_count += 1
                for ban in bans:
                    ip = normalize_ip(ban.get("ip", ""))
                    if not ip:
                        continue
                    if self.db.is_blocked(ip):
                        continue
                    if self.firewall.is_whitelisted(ip):
                        continue
                    # 应用对端封禁
                    atype = f"peer:{ban.get('attack_type', 'unknown')}"
                    permanent = ban.get("permanent", False)
                    if permanent:
                        duration = PERMANENT_BAN_SECONDS
                    else:
                        # 从 unblock_at 计算剩余封禁时长
                        unblock_at = ban.get("unblock_at", "")
                        try:
                            unblock_ts = time.mktime(
                                time.strptime(unblock_at, "%Y-%m-%d %H:%M:%S"))
                            duration = max(int(unblock_ts - time.time()), 60)
                        except (ValueError, TypeError):
                            duration = 86400  # 默认 24 小时
                    if self.firewall.ban(ip):
                        self.db.block_ip(ip, atype, duration,
                                         permanent=permanent)
                        synced += 1
                        logger.info("联动封禁: %s (来源: %s)", ip, peer["url"])
            except Exception as e:
                fail_count += 1
                logger.debug("节点 %s 同步失败: %s", peer["url"], e)

        self._fed_stats = {
            "peers_ok": ok_count,
            "peers_fail": fail_count,
            "bans_synced": synced,
        }
        if synced > 0:
            logger.info("分布式同步完成: %d 个节点, 同步 %d 条封禁",
                        ok_count, synced)

    def _fetch_peer_bans(self, peer):
        """从对端节点获取封禁列表。"""
        url = f"{peer['url']}/api/bans"
        headers = {}
        if peer.get("token"):
            headers["Authorization"] = f"Bearer {peer['token']}"
        try:
            req = urllib.request.Request(url, headers=headers, method="GET")
            with urllib.request.urlopen(req, timeout=15) as resp:
                data = json.loads(resp.read())
                return data.get("bans", [])
        except Exception:
            return None


# ── CLI 入口 ──────────────────────────────────────────────────

def cmd_ban(engine, ip):
    ip = normalize_ip(ip)
    if engine.firewall.is_whitelisted(ip):
        print(f"[!] {ip} 在白名单中，跳过")
        return
    if engine.db.is_blocked(ip):
        print(f"[!] {ip} 已在封禁列表中")
        return
    if engine.firewall.ban(ip):
        engine.db.block_ip(ip, "manual", PERMANENT_BAN_SECONDS, permanent=True)
        engine.db.record_attack(ip, "manual", 0, blocked=True)
        engine.db.flush()
        print(f"[✓] 已封禁 {ip}")
    else:
        print(f"[✗] 封禁失败")


def cmd_unban(engine, ip):
    ip = normalize_ip(ip)
    if not engine.db.is_blocked(ip):
        print(f"[!] {ip} 不在封禁列表中")
        return
    engine.firewall.unban(ip)
    engine.db.unblock_ip(ip)
    print(f"[✓] 已解封 {ip}")


def main():
    parser = argparse.ArgumentParser(
        description="PortSentinel 端口安全监控引擎")
    parser.add_argument(
        "-config", dest="config_path", help="配置文件路径")
    parser.add_argument(
        "command", nargs="?", choices=["ban", "unban"], help="手动操作")
    parser.add_argument("ip", nargs="?", help="目标 IP")
    parser.add_argument(
        "-v", "--version", action="version",
        version=f"PortSentinel v{VERSION}")

    args = parser.parse_args()

    if args.command and args.ip:
        if not args.config_path:
            args.config_path = "/etc/port-monitor/config.yaml"
        engine = PortSentinel(args.config_path)
        if args.command == "ban":
            cmd_ban(engine, args.ip)
        elif args.command == "unban":
            cmd_unban(engine, args.ip)
        engine.db.close()
    elif args.config_path:
        engine = PortSentinel(args.config_path)
        engine.start()
    else:
        parser.print_help()
        sys.exit(1)


if __name__ == "__main__":
    main()
