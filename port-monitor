class HoneypotService:
    """在蜜罐端口运行协议模拟服务，捕获攻击者行为。"""

    _SSH_BANNER = b"SSH-2.0-OpenSSH_8.9p1 Ubuntu-3ubuntu0.1\r\n"
    _HTTP_RESP = (b"HTTP/1.1 200 OK\r\nContent-Type: text/html\r\n\r\n"
                  b"<html><body><h1>Admin Panel</h1>"
                  b"<form method=post><input name=user><input name=pass type=password>"
                  b"<button>Login</button></form></body></html>")
    _REDIS_RESP = b"+OK\r\n"
    _RDP_BANNER = b"\x03\x00\x00\x13\x0e\xd0\x00\x00\x124\x00\x02\x1f\x08\x00\x02\x00\x00\x00"

    def __init__(self, config, alert_callback=None):
        hp_cfg = config.get("honeypot", {})
        self._enabled = hp_cfg.get("enabled", False)
        self._ports = hp_cfg.get("ports", [])
        self._services = hp_cfg.get("services", {})
        self._alert_cb = alert_callback
        self._running = False

    def start(self):
        if not self._enabled:
            return
        self._running = True
        for port in self._ports:
            svc = self._services.get(str(port), self._guess_service(port))
            threading.Thread(target=self._listen, args=(port, svc), daemon=True).start()
        logger.info("蜜罐服务: %d 个端口已启动", len(self._ports))

    def stop(self):
        self._running = False

    @staticmethod
    def _guess_service(port):
        return {22: "ssh", 80: "http", 443: "http", 3306: "mysql",
                3389: "rdp", 6379: "redis", 8080: "http"}.get(port, "generic")

    def _listen(self, port, service):
        try:
            srv = socket.socket(socket.AF_INET, socket.SOCK_STREAM)
            srv.setsockopt(socket.SOL_SOCKET, socket.SO_REUSEADDR, 1)
            srv.settimeout(1.0)
            srv.bind(("0.0.0.0", port))
            srv.listen(5)
            logger.info("蜜罐服务监听 :%d [%s]", port, service)
            while self._running:
                try:
                    conn, addr = srv.accept()
                    threading.Thread(target=self._handle, args=(conn, addr, port, service), daemon=True).start()
                except socket.timeout:
                    continue
                except OSError:
                    break
            srv.close()
        except Exception as e:
            logger.debug("蜜罐服务 :%d 启动失败: %s", port, e)

    def _handle(self, conn, addr, port, service):
        try:
            conn.settimeout(10)
            banner = {"ssh": self._SSH_BANNER, "http": self._HTTP_RESP,
                      "redis": self._REDIS_RESP, "rdp": self._RDP_BANNER}.get(service, b"")
            if banner:
                conn.send(banner)
            data = b""
            try:
                data = conn.recv(4096)
            except (socket.timeout, OSError):
                pass
            if data:
                logger.warning("🍯 蜜罐捕获 :%d [%s] from %s | data=%d bytes | %s",
                               port, service, addr[0], len(data), repr(data[:100]))
                if self._alert_cb:
                    self._alert_cb(addr[0], port, service, data[:200])
        except Exception:
            pass
        finally:
            try:
                conn.close()
            except Exception:
                pass


